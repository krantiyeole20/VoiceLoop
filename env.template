# =============================================================================
# VoiceLoop — Environment Template
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# ── LiveKit (server-side defaults for testing; production uses BYOK) ─────────
# Get from: https://cloud.livekit.io/  →  Project  →  Settings  →  Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── OpenAI / Deepgram (server-side defaults for build scripts; production uses BYOK) ─
# OPENAI_API_KEY is required by generate_welcome_audio.py to pre-generate MP3 assets.
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=                  # service_role JWT — bypasses RLS, SERVER ONLY
SUPABASE_ANON_KEY=                     # anon JWT — used by auth_helpers for user-token validation
SUPABASE_JWT_SECRET=                   # for inbound JWT verification (matches Supabase project setting)

# ── Crypto ──────────────────────────────────────────────────────────────────
# FERNET_KEY must be a 32-byte url-safe base64 string. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Legacy alias — supabase_client.py reads FERNET_KEY first, then ENCRYPTION_KEY.
ENCRYPTION_KEY=
# Flask session signing key. Use a random 32+ char string.
FLASK_SECRET_KEY=
# MockFlow compat alias for FLASK_SECRET_KEY.
SECRET_KEY=

# ── Google OAuth (configured in Supabase Auth → Providers → Google) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Eval layer (Phase 3+) ───────────────────────────────────────────────────
EVAL_PATCHES_DIR=eval_patches/
PROMPT_VERSIONS_DIR=prompt_versions/
EVAL_RUBRIC_VERSION=1

# ── Runtime ─────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_PORT=5000
MAX_CONCURRENT_WORKERS=10
LOG_LEVEL=INFO
